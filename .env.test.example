# Test environment variables
# Copy to .env.test and fill in values

TEST_ENV=local

# Base URL for Playwright E2E tests
BASE_URL=http://localhost:3000

# Clerk test credentials (use Clerk's test mode)
# See: https://clerk.com/docs/testing/playwright
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Test user credentials (Clerk test user)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test-password-here

# Admin test user (for protected route tests)
TEST_ADMIN_USER_ID=user_...
